				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const data = pm.iterationData.toObject()",
							"console.log(data);",
							"",
							"let page = data.page;",
							"let query_string = '';",
							"",
							"if (data.page.includes('?')) {",
							"    const desct = data.page.split('?');",
							"    page = desct[0];",
							"    query_string = desct[1];",
							"}",
							"",
							"pm.variables.set('session_ref', data.sessionRef)",
							"pm.variables.set('club_id', data.club_id)",
							"",
							"pm.variables.set('client_ip', data.client_ip)",
							"pm.variables.set('client_browser', data.user_agent_browser)",
							"pm.variables.set('client_os', data.user_agent_os)",
							"pm.variables.set('client_device', data.user_agent_device)",
							"",
							"pm.variables.set('page_path', page)",
							"pm.variables.set('page_query', query_string)",
							"pm.variables.set('date', data.timestamp)",
							"",
							"",
							""
						],
						"type": "text/javascript",
