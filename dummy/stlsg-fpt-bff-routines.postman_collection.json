		{
			"name": "[RUNNER] Create Feedback Emoji",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"const data = pm.iterationData.toObject()",
							"console.log(data);",
							"",
							"const moods = ['happy', 'neutral', 'sad'];",
							"var randomIndex = Math.floor(Math.random() * moods.length);",
							"const emoji = moods[randomIndex];",
							"",
							"const user_context = {",
							"  \"ip\": \"10.40.3.1\",",
							"  \"user_agent\": \"AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36\",",
							"  \"session_id\": data.session_id",
							"}",
							"",
							"var jsonString = JSON.stringify(user_context);",
							"var base64Result = btoa(jsonString);",
							"",
							"pm.variables.set('user_context', base64Result)",
							"",
							"pm.variables.set('emoji', emoji)",
							"pm.variables.set('club_id', data.club_id)",
							"pm.variables.set('page', '/')",
							"",
							""
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
